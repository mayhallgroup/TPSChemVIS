{#
  TPSCI driver for excited states with charge-transfer (CT) Fock sectors.

  Adapted from:
    TPSCI-TM_data/charge_transfer/fe_conocl/cisd-cmf.jl   (FermiCG API)
  Translated to TPSChem.jl API, verified against:
    test/test_openshell.jl     (add_spin_focksectors, open-shell TPSCI)
    examples/notes/tpsci.jl    (manual CT Fock sectors, merge_cluster_bases)

  Strategy
  --------
  1. Build spin-adapted cluster eigenbasis for reference + each CT Fock sector
     using compute_cluster_eigenbasis_spin + merge_cluster_bases.
  2. Seed the TPSCIstate with:
       a) Local single/double excitations within the reference Fock sector.
       b) add_spin_focksectors for ΔM_S=±1 sectors.
       c) Explicit charge-transfer Fock sectors (MLCT / LMCT).
  3. Run TPSCI.

  CT pairs format (ct_pairs variable below):
    Each pair (src, dst) transfers one α electron from cluster src to dst.
    For β transfer swap roles. Both directions should be listed for MLCT + LMCT.
    EDIT the ct_pairs list below to match your molecule's chemistry.
#}
# Auto-generated by Active Space Builder — edit driver_tpsci_ct.jl.j2 to change.

using TPSChem
using TPSChem.QCBase
using TPSChem.RDM
using JLD2
using Printf

println("[tpsci_ct] loading CMF result from {{ cmf_result_path }}")
@load "{{ cmf_result_path }}" ints clusters init_fspace d1 e_cmf U

max_roots = {{ max_roots | default(100) }}
nroots    = {{ nroots | default(4) }}
# --- reference Fock config (open-shell broken-symmetry) --------------------------
# add_spin_focksectors / spin sectors conserve the GLOBAL (nα,nβ); to reach a low-spin
# (antiferromagnetic) manifold from a high-spin CMF reference you must flip one (or
# more) open-shell clusters' (nα,nβ) -> (nβ,nα) here. E.g. flipping cluster 3 turns
# [(3,0),(3,3),(3,0)] (M_S=3) into [(3,0),(3,3),(0,3)] (M_S=0).
ref_fspace = [f for f in init_fspace]
{% if flip_clusters | default([]) %}
# Explicit spin-flip list from the GUI — overrides the auto default.
{% for c in flip_clusters %}
ref_fspace[{{ c }}] = (init_fspace[{{ c }}][2], init_fspace[{{ c }}][1])   # spin-flip cluster {{ c }}
{% endfor %}
{% elif auto_flip | default(false) %}
# Auto broken-symmetry default (open-shell): alternate the spin of the open-shell
# clusters so the global M_S is minimized (antiferromagnetic reference).
let flip = false
    for i in 1:length(ref_fspace)
        na, nb = ref_fspace[i]
        na == nb && continue           # skip closed-shell clusters
        flip && (ref_fspace[i] = (nb, na))
        flip = !flip
    end
end
{% endif %}
ref_fock  = TPSChem.FockConfig(ref_fspace)
println("[ref] reference Fock config = ", ref_fock)

println("[tpsci_ct] building reference cluster eigenbasis (spin-adapted)")
# delta_elec: electrons added/removed per cluster for the spin-adapted eigenbasis
# (2–3 per cluster is typical for bimetallics). Set in the GUI.
delta_elec = [{{ delta_elec | default(3) }} for _ in clusters]
cluster_bases = TPSChem.compute_cluster_eigenbasis_spin(
    ints, clusters, d1, delta_elec, ref_fock;
    max_roots=max_roots, verbose={{ verbose | default(1) }})

# ── CT Fock sectors ─────────────────────────────────────────────────────────
# Edit this list to match your system's physically relevant charge-transfer channels.
# Each FockConfig lists (n_alpha, n_beta) per cluster.
# Pattern: examples/notes/tpsci.jl — spin partner + MLCT + LMCT + spin-exchange.
#
# Example for 3-cluster bimetallic M1–L–M2 with init_fspace=[(na1,nb1),(naL,nbL),(na2,nb2)]:
#   FockConfig([(na1-1, nb1), (naL, nbL),   (na2+1, nb2)]),  # α: M1→M2
#   FockConfig([(na1,   nb1), (naL-1, nbL), (na2+1, nb2)]),  # α: L→M2
#   FockConfig([(na1+1, nb1), (naL, nbL),   (na2-1, nb2)]),  # α: M2→M1
#   FockConfig([(na1+1, nb1), (naL-1, nbL), (na2,   nb2)]),  # α: L→M1
#   FockConfig([(na1, nb1-1), (naL, nbL),   (na2, nb2+1)]),  # β: M1→M2
#   ...
#
# ── EDIT BELOW ───────────────────────────────────────────────────────────────
ct_fspaces = FockConfig[]
# Uncomment and adapt:
# push!(ct_fspaces, FockConfig([...]))   # α: cluster 1 → cluster 3 (MLCT)
# push!(ct_fspaces, FockConfig([...]))   # α: cluster 3 → cluster 1 (LMCT)
# push!(ct_fspaces, FockConfig([...]))   # spin-flipped reference partner
# ── END EDIT ─────────────────────────────────────────────────────────────────

for fs in ct_fspaces
    cb = TPSChem.compute_cluster_eigenbasis_spin(
        ints, clusters, d1, delta_elec, fs;
        max_roots=max_roots, verbose=0)
    global cluster_bases
    cluster_bases = TPSChem.merge_cluster_bases(cluster_bases, cb)
end

clustered_ham = TPSChem.extract_ClusteredTerms(ints, clusters)
cluster_ops   = TPSChem.compute_cluster_ops(cluster_bases, ints)
TPSChem.add_cmf_operators!(cluster_ops, cluster_bases, ints, d1.a, d1.b)

ci_vector = TPSChem.TPSCIstate(clusters, ref_fock, R=nroots, T=Float64)

# ── Spin-flip sectors (M_S ± 1) ─────────────────────────────────────────────
# add_spin_focksectors adds all sectors reachable by one α↔β flip on any cluster.
ci_vector = TPSChem.add_spin_focksectors(ci_vector)

# ── Add CT Fock sectors to the search space ──────────────────────────────────
for fs in ct_fspaces
    TPSChem.add_fockconfig!(ci_vector, fs)
    # Seed ground-state config in this Fock sector
    ci_vector[fs][TPSChem.ClusterConfig([1 for _ in clusters])] = zeros(Float64, nroots)
end

# ── Seed reference Fock sector ───────────────────────────────────────────────
# Ground state
begin
    seed = zeros(Float64, nroots); seed[1] = 1.0
    ci_vector[ref_fock][TPSChem.ClusterConfig([1 for _ in clusters])] = seed
end

# Local single-cluster excitations (roots 2..nroots)
n_excite = nroots - 1
for c_idx in 1:length(clusters)
    for state_idx in 2:(min(n_excite, {{ max_local_roots | default(3) }}) + 1)
        cfg = [i == c_idx ? state_idx : 1 for i in 1:length(clusters)]
        ci_vector[ref_fock][TPSChem.ClusterConfig(cfg)] = zeros(Float64, nroots)
    end
end

# Local double-cluster excitations (pairs within reference Fock sector)
{% if add_double_excitations | default(true) %}
for ci in 1:length(clusters), cj in (ci+1):length(clusters)
    for si in 2:{{ max_local_roots | default(3) }}, sj in 2:{{ max_local_roots | default(3) }}
        cfg = [k==ci ? si : k==cj ? sj : 1 for k in 1:length(clusters)]
        ci_vector[ref_fock][TPSChem.ClusterConfig(cfg)] = zeros(Float64, nroots)
    end
end
{% endif %}

println("[tpsci_ct] ci_vector Fock sectors: ", length(keys(ci_vector.data)))

println("[tpsci_ct] running TPSCI (nroots=", nroots, ")")
e0, v0 = TPSChem.tpsci_ci(ci_vector, cluster_ops, clustered_ham;
    incremental      = true,
    ci_conv          = {{ ci_conv | default("1e-8") }},
    thresh_cipsi     = {{ thresh_cipsi | default("5e-3") }},
    thresh_foi       = {{ thresh_foi | default("1e-4") }},
    thresh_asci      = {{ thresh_asci | default("-1") }},
    conv_thresh      = {{ conv_thresh | default("1e-6") }})

e2 = TPSChem.compute_pt2_energy(v0, cluster_ops, clustered_ham;
    thresh_foi={{ pt2_thresh_foi | default("1e-4") }})

@printf("[tpsci_ct] E(TPSCI)     = %s\n", string(e0))
@printf("[tpsci_ct] E(TPSCI+PT2) = %s\n", string(e0 .+ e2))

{% if compute_s2 | default(true) %}
# S² expectation values — useful to track spin contamination in low-spin excited states
clustered_S2 = TPSChem.extract_S2(clusters)
s2 = TPSChem.compute_expectation_value_parallel(v0, cluster_ops, clustered_S2)
@printf("[tpsci_ct] <S²> = %s\n", string(s2))
{% endif %}

mkpath("{{ output_dir }}")
jldsave("{{ output_dir }}/tpsci_ct_result.jld2";
    e0=e0, e2=e2, v0=v0,
    cluster_bases=cluster_bases,
    init_fspace=init_fspace)
open("{{ output_dir }}/energies.txt", "w") do io
    println(io, "E(TPSCI):     ", e0)
    println(io, "E(PT2):       ", e2)
    println(io, "E(TPSCI+PT2): ", e0 .+ e2)
end
println("[tpsci_ct] done → {{ output_dir }}/tpsci_ct_result.jld2")
