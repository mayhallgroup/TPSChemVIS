using TPSChem
using TPSChem.QCBase
using TPSChem.RDM
using JLD2
using Printf

println("[spt] loading CMF result from {{ cmf_result_path }}")
@load "{{ cmf_result_path }}" ints clusters init_fspace d1 e_cmf U

max_roots = {{ max_roots | default(50) }}
nroots    = {{ nroots | default(4) }}
# --- reference Fock config (open-shell broken-symmetry) --------------------------
# add_spin_focksectors / spin sectors conserve the GLOBAL (nα,nβ); to reach a low-spin
# (antiferromagnetic) manifold from a high-spin CMF reference you must flip one (or
# more) open-shell clusters' (nα,nβ) -> (nβ,nα) here. E.g. flipping cluster 3 turns
# [(3,0),(3,3),(3,0)] (M_S=3) into [(3,0),(3,3),(0,3)] (M_S=0).
ref_fspace = [f for f in init_fspace]
{% if flip_clusters | default([]) %}
# Explicit spin-flip list from the GUI — overrides the auto default.
{% for c in flip_clusters %}
ref_fspace[{{ c }}] = (init_fspace[{{ c }}][2], init_fspace[{{ c }}][1])   # spin-flip cluster {{ c }}
{% endfor %}
{% elif auto_flip | default(false) %}
# Auto broken-symmetry default (open-shell): alternate the spin of the open-shell
# clusters so the global M_S is minimized (antiferromagnetic reference).
let flip = false
    for i in 1:length(ref_fspace)
        na, nb = ref_fspace[i]
        na == nb && continue           # skip closed-shell clusters
        flip && (ref_fspace[i] = (nb, na))
        flip = !flip
    end
end
{% endif %}
ref_fock  = TPSChem.FockConfig(ref_fspace)
println("[ref] reference Fock config = ", ref_fock)

function build_low_spin_p_spaces(clusters, ref_fspace; roots_per_sector=1)
    p_spaces = TPSChem.ClusterSubspace[]
    for ci in clusters
        fock = ref_fspace[ci.idx]
        na = Int(fock[1])
        nb = Int(fock[2])
        ssi = TPSChem.ClusterSubspace(clusters[ci.idx])

        if na == nb
            TPSChem.add_subspace!(ssi, (na, nb), 1:roots_per_sector)
        else
            high = max(na, nb)
            low = min(na, nb)
            total = high + low
            for nalpha in high:-1:low
                TPSChem.add_subspace!(ssi, (nalpha, total - nalpha), 1:roots_per_sector)
            end
        end

        push!(p_spaces, ssi)
    end
    return p_spaces
end

function _available_spt_subspace(v, ck, fk)
    if haskey(v.p_spaces[ck], fk)
        return v.p_spaces[ck][fk]
    elseif haskey(v.q_spaces[ck], fk)
        return v.q_spaces[ck][fk]
    end
    return nothing
end

function add_available_spin_flip_states!(v::TPSChem.SPTstate{T,N,R},
        fspace0::TPSChem.FockConfig{N}, nroots::Integer) where {T,N,R}
    added = 0
    for ci in 1:N, cj in 1:N
        ci == cj && continue

        flip_ab = TPSChem.replace(fspace0, [ci, cj], [
            (fspace0[ci][1] + 1, fspace0[ci][2] - 1),
            (fspace0[cj][1] - 1, fspace0[cj][2] + 1),
        ])
        flip_ba = TPSChem.replace(fspace0, [ci, cj], [
            (fspace0[ci][1] - 1, fspace0[ci][2] + 1),
            (fspace0[cj][1] + 1, fspace0[cj][2] - 1),
        ])

        for fconfig_ij in (flip_ab, flip_ba)
            any(f -> f[1] < 0 || f[2] < 0, fconfig_ij.config) && continue

            ranges = UnitRange{Int16}[]
            valid = true
            for (ck, fk) in enumerate(fconfig_ij.config)
                range = _available_spt_subspace(v, ck, fk)
                if range === nothing
                    valid = false
                    break
                end
                push!(ranges, range)
            end
            valid || continue

            tconf = TPSChem.TuckerConfig(ranges)
            haskey(v.data, fconfig_ij) || TPSChem.add_fockconfig!(v, fconfig_ij)
            haskey(v.data[fconfig_ij], tconf) && continue

            core = tuple([zeros(length.(tconf)...) for _ in 1:R]...)
            core, factors = TPSChem.tucker_initialize(core; num_roots=nroots)
            v.data[fconfig_ij][tconf] = TPSChem.Tucker(TPSChem.Tucker(core, factors); R, T)
            added += 1
        end
    end
    println("[spt] added ", added, " available spin-flip Tucker sectors")
    return v
end

println("[spt] building spin-adapted cluster eigenbasis")
# compute_cluster_eigenbasis_spin is required for bimetallics with open-shell clusters.
# Verified: test/test_openshell.jl and test/test_variance.jl.
# delta_elec: electrons added/removed per cluster for the spin-adapted eigenbasis
# (2–3 per cluster is typical for bimetallics). Set in the GUI.
delta_elec = [{{ delta_elec | default(3) }} for _ in clusters]
cluster_bases = TPSChem.compute_cluster_eigenbasis_spin(
    ints, clusters, d1, delta_elec, ref_fock;
    max_roots=max_roots, verbose={{ verbose | default(1) }})

clustered_ham = TPSChem.extract_ClusteredTerms(ints, clusters)
cluster_ops   = TPSChem.compute_cluster_ops(cluster_bases, ints)
TPSChem.add_cmf_operators!(cluster_ops, cluster_bases, ints, d1.a, d1.b)

{% if spt_space_mode | default("open_shell") == "ct" %}
# ── SPT+CT / excitonic P-space ───────────────────────────────────────────────
# Direct SPTstate seed following examples/tetracene_dimer/spt_direct.jl:
# reference + local single excitons + local double excitons + spin-flip states.
v_seed = TPSChem.SPTstate(clusters, ref_fock, cluster_bases, R=nroots)
TPSChem.add_single_excitons!(v_seed, ref_fock, {{ single_excitons_roots | default("nroots") }})
TPSChem.add_double_excitons!(v_seed, ref_fock, {{ double_excitons_roots | default("nroots") }})
add_available_spin_flip_states!(v_seed, ref_fock, {{ spin_flip_roots | default(1) }})
TPSChem.eye!(v_seed)
{% else %}
# ── Low-spin open-shell SPT P-space ──────────────────────────────────────────
# Automatic version of the Cr2/Fe bimetallic p_spaces:
#   open-shell (6,3) or (3,6) -> (6,3),(5,4),(4,5),(3,6)
#   closed-shell (4,4)        -> (4,4)
p_spaces = build_low_spin_p_spaces(
    clusters, ref_fspace; roots_per_sector={{ p_space_roots | default(1) }})
v_seed = TPSChem.SPTstate(clusters, p_spaces, cluster_bases, R=nroots)
na = sum(f[1] for f in ref_fspace)
nb = sum(f[2] for f in ref_fspace)
TPSChem.fill_p_space!(v_seed, na, nb)
TPSChem.eye!(v_seed)
{% endif %}
seed_p_spaces = v_seed.p_spaces
display(v_seed)

println("[spt] CI solve in SPT P-space (nroots=", nroots, ")")
e_ci, v_ci = TPSChem.ci_solve(v_seed, cluster_ops, clustered_ham;
    solver="{{ solver | default('davidson') }}", verbose={{ verbose | default(1) }})
@printf("[spt] E(CI/SPT seed) = %s\n", string(e_ci))

println("[spt] running subspace_product_tucker (replaces block_sparse_tucker)")
e_var, v_var = TPSChem.subspace_product_tucker(v_ci, cluster_ops, clustered_ham;
    max_iter    = {{ max_iter | default(50) }},
    nbody       = {{ nbody | default(4) }},
    H0          = "{{ H0 | default('Hcmf') }}",
    thresh_var  = {{ thresh_var | default("1e-2") }},
    thresh_foi  = {{ thresh_foi | default("1e-4") }},
    thresh_pt   = {{ thresh_pt | default("5e-3") }},
    thresh_spin = {{ thresh_spin | default(thresh_var | default("1e-2")) }},
    ci_conv     = {{ ci_conv | default("1e-5") }},
    do_pt       = {{ do_pt | default(true) | lower }},
    resolve_ss  = {{ resolve_ss | default(false) | lower }},
    tol_tucker  = {{ tol_tucker | default("1e-4") }},
    solver      = "{{ solver | default('davidson') }}")

@printf("[spt] E(SPT) = %s\n", string(e_var))

{% if compute_s2 | default(true) %}
# S² — track spin purity of low-spin states (key diagnostic for bimetallics)
clustered_S2 = TPSChem.extract_S2(clusters)
s2 = TPSChem.compute_expectation_value(v_var, cluster_ops, clustered_S2)
@printf("[spt] <S²> = %s\n", string(s2))
{% endif %}

# ── Post-SPT analysis ────────────────────────────────────────────────────────
{% if post_analysis | default("none") == "pt2" %}
println("[spt] computing PT2 correction on SPT wavefunction")
e2 = TPSChem.compute_pt2_energy_blockwise(
    v_var, cluster_ops, clustered_ham;
    H0="{{ H0 | default('Hcmf') }}",
    nbody={{ nbody | default(4) }},
    thresh_foi={{ post_thresh_foi | default("1e-4") }},
    max_number=nothing,
    opt_ref=false,
    ci_tol={{ ci_conv | default("1e-6") }},
    verbose={{ verbose | default(1) }})
@printf("[spt] E(SPT+PT2) = %s\n", string(e_var .+ e2))
{% elif post_analysis | default("none") == "variance" %}
println("[spt] computing variance-like SPT sigma norm")
sigma2 = TPSChem.compute_spt_sigma_norm_blockwise_alternative(
    v_var, cluster_ops, clustered_ham;
    H0="{{ H0 | default('Hcmf') }}",
    nbody={{ nbody | default(4) }},
    thresh_foi={{ post_thresh_foi | default("1e-4") }},
    max_number=nothing,
    opt_ref=false,
    ci_tol={{ ci_conv | default("1e-6") }},
    verbose={{ verbose | default(1) }})
var_e = sigma2 .- e_var.^2
@printf("[spt] sigma2 = %s\n", string(sigma2))
@printf("[spt] Var(E) = %s\n", string(var_e))
{% endif %}

mkpath("{{ output_dir }}")
