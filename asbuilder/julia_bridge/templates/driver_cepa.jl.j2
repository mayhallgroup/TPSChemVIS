{#
  FOIS-CEPA driver — for bimetallics and open-shell systems.

  Adapted from reference CEPA script (FermiCG.do_fois_cepa → TPSChem.do_fois_cepa).
  Key feature: convergence sweep over decreasing thresh_foi to extrapolate to the
  complete FOIS limit (same strategy as the reference bimetallic CEPA scripts).

  Verified against:
    examples/cepa.jl
    examples/cepa_multiroot.jl
    examples/cr2_13_cepa.jl

  For open-shell / bimetallic systems:
    - Uses compute_cluster_eigenbasis_spin (not compute_cluster_eigenbasis)
    - Adds spin Fock sectors with add_spin_focksectors before CI
    - Runs tps_ci_direct first to get a good reference state
    - Sweeps thresh_foi (coarse → tight) to monitor convergence
#}
# Auto-generated by Active Space Builder — edit driver_cepa.jl.j2 to change.

using TPSChem
using TPSChem.QCBase
using TPSChem.RDM
using JLD2
using Printf

println("[cepa] loading CMF result from {{ cmf_result_path }}")
@load "{{ cmf_result_path }}" ints clusters init_fspace d1 e_cmf U

max_roots = {{ max_roots | default(100) }}
nroots    = {{ nroots | default(4) }}
# --- reference Fock config (open-shell broken-symmetry) --------------------------
# add_spin_focksectors / spin sectors conserve the GLOBAL (nα,nβ); to reach a low-spin
# (antiferromagnetic) manifold from a high-spin CMF reference you must flip one (or
# more) open-shell clusters' (nα,nβ) -> (nβ,nα) here. E.g. flipping cluster 3 turns
# [(3,0),(3,3),(3,0)] (M_S=3) into [(3,0),(3,3),(0,3)] (M_S=0).
ref_fspace = [f for f in init_fspace]
{% if flip_clusters | default([]) %}
# Explicit spin-flip list from the GUI — overrides the auto default.
{% for c in flip_clusters %}
ref_fspace[{{ c }}] = (init_fspace[{{ c }}][2], init_fspace[{{ c }}][1])   # spin-flip cluster {{ c }}
{% endfor %}
{% elif auto_flip | default(false) %}
# Auto broken-symmetry default (open-shell): alternate the spin of the open-shell
# clusters so the global M_S is minimized (antiferromagnetic reference).
let flip = false
    for i in 1:length(ref_fspace)
        na, nb = ref_fspace[i]
        na == nb && continue           # skip closed-shell clusters
        flip && (ref_fspace[i] = (nb, na))
        flip = !flip
    end
end
{% endif %}
ref_fock  = TPSChem.FockConfig(ref_fspace)
println("[ref] reference Fock config = ", ref_fock)

println("[cepa] building spin-adapted cluster eigenbasis")
{% if spin_adapt | default(true) %}
# compute_cluster_eigenbasis_spin: required for bimetallics / open-shell clusters.
# delta_elec: electrons added/removed per cluster for the spin-adapted eigenbasis
# (2–3 per cluster is typical for bimetallics). Set in the GUI.
delta_elec = [{{ delta_elec | default(3) }} for _ in clusters]
cluster_bases = TPSChem.compute_cluster_eigenbasis_spin(
    ints, clusters, d1, delta_elec, ref_fock;
    max_roots=max_roots, verbose={{ verbose | default(1) }})
{% else %}
cluster_bases = TPSChem.compute_cluster_eigenbasis(ints, clusters;
    verbose={{ verbose | default(1) }}, max_roots=max_roots,
    init_fspace=init_fspace, rdm1a=d1.a, rdm1b=d1.b)
{% endif %}

clustered_ham = TPSChem.extract_ClusteredTerms(ints, clusters)
cluster_ops   = TPSChem.compute_cluster_ops(cluster_bases, ints)
TPSChem.add_cmf_operators!(cluster_ops, cluster_bases, ints, d1.a, d1.b)

# ── Reference CI state ───────────────────────────────────────────────────────
ci_vector = TPSChem.TPSCIstate(clusters, ref_fock, R=nroots, T=Float64)
{% if add_spin_fock | default(true) %}
ci_vector = TPSChem.add_spin_focksectors(ci_vector)
{% endif %}

# Seed ground state
begin
    seed = zeros(Float64, nroots); seed[1] = 1.0
    ci_vector[ref_fock][TPSChem.ClusterConfig([1 for _ in clusters])] = seed
end

println("[cepa] initial CI solve")
eci, v_ref = TPSChem.tps_ci_direct(ci_vector, cluster_ops, clustered_ham)
@printf("[cepa] E(CI) = %s\n", string(eci))

# ── CEPA convergence sweep (coarse → tight) ───────────────────────────────
# Run CEPA at decreasing thresh_foi to extrapolate to the complete FOIS limit.
# Edit the threshold list to control the sweep — match your convergence budget.
cepa_thresholds = {{ thresh_foi_list | default("[1e-3, 5e-4, 1e-4, 5e-5]") }}
cepa_shift      = "{{ cepa_shift | default('cepa') }}"   # "cepa", "cisd", "acpf", "aqcc"
nbody           = {{ nbody | default(4) }}
tol             = {{ tol | default("1e-8") }}
thresh_sigma    = {{ thresh_sigma | default("1e-6") }}

e_cepa = nothing
v_cepa = deepcopy(v_ref)

for thresh_foi in cepa_thresholds
    global e_cepa, v_cepa
    @printf("\n[cepa] CEPA-0 [cepa_shift=%s, thresh_foi=%.1e]\n", cepa_shift, thresh_foi)
    GC.gc()
    result = @timed TPSChem.do_fois_cepa(v_cepa, cluster_ops, clustered_ham;
        cepa_shift   = cepa_shift,
        thresh_foi   = thresh_foi,
        nbody        = nbody,
        tol          = tol,
        thresh_sigma = thresh_sigma,
        solver       = :{{ solver | default('minres') }},
        build_hqq    = :{{ build_hqq | default('matvec') }},
        verbose      = {{ verbose | default(1) }})
    e_cepa, v_cepa = result.value
    @printf("[cepa] E(CEPA, thresh=%.1e) = %s   time=%.1f s\n",
            thresh_foi, string(e_cepa), result.time)
end

@printf("[cepa] Final E(CEPA) = %s\n", string(e_cepa))

mkpath("{{ output_dir }}")
jldsave("{{ output_dir }}/cepa_result.jld2";
    e_cepa=e_cepa, v_cepa=v_cepa, eci=eci,
    cluster_bases=cluster_bases,
    init_fspace=init_fspace)
open("{{ output_dir }}/energies.txt", "w") do io
    println(io, "E(CI):   ", eci)
    println(io, "E(CEPA): ", e_cepa)
end
println("[cepa] done → {{ output_dir }}/cepa_result.jld2")
