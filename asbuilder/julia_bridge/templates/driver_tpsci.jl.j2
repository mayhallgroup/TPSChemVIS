{#
  TPSCI driver — ground state or open-shell low-spin states.

  Verified against:
    test/test_tpsci.jl        (closed-shell, multi-root seeding)
    test/test_openshell.jl    (open-shell, add_spin_focksectors)
    examples/notes/tpsci.jl

  Key knobs
  ---------
  spin_adapt        true  → compute_cluster_eigenbasis_spin (required for bimetallics,
                            any system where the CMF reference is NOT closed-shell)
                    false → compute_cluster_eigenbasis (closed-shell)
  add_spin_fock     true  → add_spin_focksectors(ci_vector) before TPSCI
                            (handles M_S ≠ 0 Fock sectors automatically — low-spin states)
  nroots            number of roots to solve for simultaneously
#}
# Auto-generated by Active Space Builder — edit driver_tpsci.jl.j2 to change.

using TPSChem
using TPSChem.QCBase
using TPSChem.RDM
using JLD2
using Printf

println("[tpsci] loading CMF result from {{ cmf_result_path }}")
@load "{{ cmf_result_path }}" ints clusters init_fspace d1 e_cmf U

max_roots = {{ max_roots | default(20) }}
nroots    = {{ nroots | default(1) }}

println("[tpsci] building cluster eigenbasis (spin_adapt={{ spin_adapt | default(false) }})")
{% if spin_adapt %}
# compute_cluster_eigenbasis_spin: required for open-shell / bimetallic systems where the
# reference Fock space is NOT closed-shell (M_S ≠ 0 clusters). Verified: test_openshell.jl.
#
# Build the TPSCI reference Fock config.  add_spin_focksectors conserves the GLOBAL
# (nα, nβ), so to target a LOW-SPIN state from a HIGH-SPIN CMF reference you must flip
# one (or more) open-shell clusters' (nα,nβ) -> (nβ,nα) here.  Example: flipping cluster 3
# turns [(3,0),(3,3),(3,0)] (M_S=3, ferromagnetic) into [(3,0),(3,3),(0,3)] (M_S=0).
# Leave flip_clusters empty if init_fspace is already the target spin arrangement.
ref_fspace = [f for f in init_fspace]
{% if flip_clusters | default([]) %}
# Explicit spin-flip list (GUI "Spin-flip clusters" field) — overrides the auto default.
{% for c in flip_clusters %}
ref_fspace[{{ c }}] = (init_fspace[{{ c }}][2], init_fspace[{{ c }}][1])   # spin-flip cluster {{ c }}
{% endfor %}
{% elif auto_flip | default(false) %}
# Auto broken-symmetry default (open-shell): alternate the spin of the open-shell
# clusters so the global M_S is minimized (antiferromagnetic reference). This turns
# e.g. [(3,0),(3,3),(3,0)] into [(3,0),(3,3),(0,3)]. Override with the GUI field.
let flip = false
    for i in 1:length(ref_fspace)
        na, nb = ref_fspace[i]
        na == nb && continue           # skip closed-shell clusters
        flip && (ref_fspace[i] = (nb, na))
        flip = !flip
    end
end
{% endif %}
ref_fock = TPSChem.FockConfig(ref_fspace)
println("[tpsci] TPSCI reference Fock config = ", ref_fock)
# delta_elec: number of electrons added/removed from each cluster's reference Fock
# sector when building its spin-adapted eigenbasis. 2–3 per cluster is typical for
# bimetallics (see FermiCG bimetallic examples). Set per-method in the GUI.
delta_elec = [{{ delta_elec | default(3) }} for _ in clusters]
cluster_bases = TPSChem.compute_cluster_eigenbasis_spin(
    ints, clusters, d1, delta_elec, ref_fock;
    max_roots=max_roots, verbose={{ verbose | default(1) }})
{% else %}
# compute_cluster_eigenbasis: closed-shell reference (all clusters doubly occupied or fully
# virtual). Verified: test_tpsci.jl, examples/notes/tpsci.jl.
cluster_bases = TPSChem.compute_cluster_eigenbasis(ints, clusters;
    verbose={{ verbose | default(1) }},
    max_roots=max_roots,
    init_fspace=init_fspace,
    rdm1a=d1.a, rdm1b=d1.b)
ref_fock = TPSChem.FockConfig(init_fspace)
{% endif %}

clustered_ham = TPSChem.extract_ClusteredTerms(ints, clusters)
cluster_ops   = TPSChem.compute_cluster_ops(cluster_bases, ints)
TPSChem.add_cmf_operators!(cluster_ops, cluster_bases, ints, d1.a, d1.b)

ci_vector = TPSChem.TPSCIstate(clusters, ref_fock, R=nroots, T=Float64)

{% if add_spin_fock %}
# add_spin_focksectors: automatically adds all Fock sectors reachable by a single α↔β
# flip on any cluster. Required for low-spin states of bimetallics (verified: test_openshell.jl).
# It also populates the reference configs across those sectors, so NO manual seed
# initialization is needed (and would be incorrect) for low-spin bimetallics.
ci_vector = TPSChem.add_spin_focksectors(ci_vector)
{% else %}

# --- seed configurations (ground state + one single-exciton per extra root) ------
# Ground state: every cluster in its local ground state (index 1).
begin
    seed = zeros(Float64, nroots); seed[1] = 1.0
    ci_vector[ref_fock][TPSChem.ClusterConfig([1 for _ in clusters])] = seed
end

# Excited roots: promote one cluster to its 1st excited state per extra root.
# Pattern from test_tpsci.jl — which cluster to excite is molecule-specific.
{% for i in range(1, nroots | default(1)) %}
# Root {{ i + 1 }}: single exciton on cluster {{ i % (nclusters | default(3)) + 1 }}
#   seed = zeros(Float64, nroots); seed[{{ i + 1 }}] = 1.0
#   cfg = [{{ 'i=='+((i % (nclusters|default(3))+1)|string)+'? 2 : 1' }} for i in 1:length(clusters)]
#   ci_vector[ref_fock][TPSChem.ClusterConfig(cfg)] = seed
{% endfor %}
{% if extra_seeds is defined and extra_seeds %}
{% for seed in extra_seeds %}
begin
    seedvec = zeros(Float64, nroots); seedvec[{{ seed.root }}] = 1.0
    ci_vector[ref_fock][TPSChem.ClusterConfig({{ seed.config }})] = seedvec
end
{% endfor %}
{% endif %}
{% endif %}

println("[tpsci] running TPSCI (nroots=", nroots, ")")
e0, v0 = TPSChem.tpsci_ci(ci_vector, cluster_ops, clustered_ham;
    incremental      = true,
    ci_conv          = {{ ci_conv | default("1e-8") }},
    thresh_cipsi     = {{ thresh_cipsi | default("1e-3") }},
    thresh_foi       = {{ thresh_foi | default("1e-4") }},
    thresh_asci      = {{ thresh_asci | default("-1") }},
    {% if thresh_spin is defined and thresh_spin %}
    thresh_spin      = {{ thresh_spin }},
    {% endif %}
    conv_thresh      = {{ conv_thresh | default("1e-7") }})

e2 = TPSChem.compute_pt2_energy(v0, cluster_ops, clustered_ham;
    thresh_foi={{ pt2_thresh_foi | default("1e-4") }})

@printf("[tpsci] E(TPSCI)     = %s\n", string(e0))
@printf("[tpsci] E(TPSCI+PT2) = %s\n", string(e0 .+ e2))

{% if compute_s2 %}
# S² expectation values (verified: test/test_s2.jl)
clustered_S2 = TPSChem.extract_S2(clusters)
s2 = TPSChem.compute_expectation_value_parallel(v0, cluster_ops, clustered_S2)
@printf("[tpsci] <S²> = %s\n", string(s2))
{% endif %}

mkpath("{{ output_dir }}")
jldsave("{{ output_dir }}/tpsci_result.jld2";
    e0=e0, e2=e2, v0=v0,
    cluster_bases=cluster_bases,
    init_fspace=init_fspace)
open("{{ output_dir }}/energies.txt", "w") do io
    println(io, "E(TPSCI): ", e0)
    println(io, "E(PT2):   ", e2)
    println(io, "E(total): ", e0 .+ e2)
end
println("[tpsci] done → {{ output_dir }}/tpsci_result.jld2")
